DATABASE_URL=postgres://kuayle:kuayle@localhost:5432/kuayle?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME_use_a_random_string_at_least_32_chars
PORT=8080
# Exact frontend origin (scheme + host + optional port). Dev Machine native
# terminal WebSockets require their Origin to match this value exactly.
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
SYSADMINS=

# Frontend demo mode (shows demo login users on /login when enabled).
# When this is true only users listed in SYSADMINS may create or use
# Dev Machines; all other authenticated users receive 403 on every
# Dev Machine API route, and the machine gateway rejects non-sysadmin
# ticket exchanges and sessions.
PUBLIC_DEMO_MODE=false
# PUBLIC_DEMO_USERS='[{"label":"Owner","email":"alice@kuayle.dev","password":"Password123!"}]'

# Storage (default: local filesystem)
# STORAGE_TYPE=local
# STORAGE_LOCAL_DIR=./uploads
# STORAGE_LOCAL_URL=/uploads

# S3-compatible storage (SeaweedFS, AWS S3, Cloudflare R2)
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_BUCKET=kuayle-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC=true
# S3_CDN_BASE_URL=

# GitHub App (SaaS mode — shared app across all workspaces)
# When set, skips per-workspace manifest setup. Each workspace only needs to install the app.
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=
# GITHUB_APP_PRIVATE_KEY=        # base64-encoded PEM: cat private-key.pem | base64
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_WEBHOOK_SECRET=

# GitHub webhook URL (optional — for dev with smee.io or private networks)
# GITHUB_WEBHOOK_URL=

# Dev Machines (disabled unless the manager, gateway, wildcard DNS, and images are configured)
# The machine domain must be a separate registrable domain, not a sibling
# subdomain of the main app. machines.localhost is the local-development
# exception. Production requires wildcard TLS via DNS-01 Caddy or a mounted cert.
# FRONTEND_URL must be the exact public frontend origin for native terminal WS.
# Workspace policy controls maximum hard runtime and idle pause; default idle
# pause is 240 minutes, keep_running=true bypasses idle pause, and no automatic
# deletion is performed.
# Workspace disk limits require Docker's data root on XFS mounted with pquota or
# prjquota. The manager fails startup when local-volume hard quotas are unavailable.
DEV_MACHINES_ENABLED=false
DEV_MACHINE_DOMAIN=machines.localhost
DEV_MACHINE_ENCRYPTION_KEY=
DEV_MACHINE_INGEST_URL=
DEV_MACHINE_SESSION_TTL_MINUTES=480
DEV_MACHINE_ACCESS_TICKET_TTL_SECONDS=60
DEV_MACHINE_GATEWAY_CONTAINER=kuayle-machine-gateway
# Pinned runtime images. The developer image includes code-server, ttyd, tmux,
# and pinned OpenCode/Claude Code/Codex CLIs; provider agent images are pinned
# separately. Use tags or digests appropriate for your deployment.
# DEV_MACHINE_IDE_IMAGE=ghcr.io/kuayle/dev-machine-ide:0.1.0
# DEV_MACHINE_BROWSER_IMAGE=ghcr.io/kuayle/dev-machine-browser:0.1.0
# DEV_MACHINE_COLLECTOR_IMAGE=ghcr.io/kuayle/dev-machine-collector:0.1.0
# DEV_MACHINE_EGRESS_IMAGE=ghcr.io/kuayle/dev-machine-egress:0.1.0
# DEV_MACHINE_CLAUDE_IMAGE=ghcr.io/kuayle/dev-machine-agent-claude:0.1.0
# DEV_MACHINE_OPENCODE_IMAGE=ghcr.io/kuayle/dev-machine-agent-opencode:0.1.0
# DEV_MACHINE_CODEX_IMAGE=ghcr.io/kuayle/dev-machine-agent-codex:0.1.0
