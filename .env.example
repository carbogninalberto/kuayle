DATABASE_URL=postgres://carbon:carbon@localhost:5432/carbon?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME_use_a_random_string_at_least_32_chars
PORT=8080
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Storage (default: local filesystem)
# STORAGE_TYPE=local
# STORAGE_LOCAL_DIR=./uploads
# STORAGE_LOCAL_URL=/uploads

# S3-compatible storage (SeaweedFS, AWS S3, Cloudflare R2)
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_BUCKET=carbon-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC=true
# S3_CDN_BASE_URL=
