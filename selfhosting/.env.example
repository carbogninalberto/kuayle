# Domain for Caddy (automatic HTTPS via Let's Encrypt)
DOMAIN=carbon.example.com

# Database
POSTGRES_USER=carbon
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=carbon

# Redis
REDIS_URL=redis://redis:6379

# Backend
JWT_SECRET=CHANGE_ME_use_a_random_string_at_least_32_chars
ENVIRONMENT=production
FRONTEND_URL=https://carbon.example.com

# Storage (default: local filesystem)
STORAGE_TYPE=local

# Uncomment for S3-compatible storage (SeaweedFS, AWS S3, Cloudflare R2)
# STORAGE_TYPE=s3
# S3_ENDPOINT=http://seaweedfs:8333
# S3_BUCKET=carbon-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC=true
# S3_CDN_BASE_URL=
