# Primary domain for Caddy (automatic HTTPS via Let's Encrypt HTTP-01 challenge).
# Must be a DNS A/AAAA record pointing to this host.
DOMAIN=kuayle.example.com

# Database
POSTGRES_USER=kuayle
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=kuayle

# Redis
REDIS_URL=redis://redis:6379

# Backend
JWT_SECRET=CHANGE_ME_use_a_random_string_at_least_32_chars
ENVIRONMENT=production
# Exact public frontend origin (scheme + host + optional port). Native Dev
# Machine terminal WebSockets require their Origin to match this value exactly.
FRONTEND_URL=https://kuayle.example.com
SYSADMINS=

# Optional one-click system updater. Set SYSADMINS first, then enable with:
# docker compose --profile updater up -d backend updater
# SYSTEM_UPDATER_URL=http://updater:8081
# SYSTEM_UPDATER_TOKEN=CHANGE_ME_random_string_at_least_32_chars

# Frontend demo mode (shows demo login users on /login when enabled).
# When this is true only users listed in SYSADMINS may create or use
# Dev Machines; all other authenticated users receive 403 on every
# Dev Machine API route, and the machine gateway rejects non-sysadmin
# ticket exchanges and sessions.
PUBLIC_DEMO_MODE=false
# PUBLIC_DEMO_USERS='[{"label":"Owner","email":"alice@kuayle.dev","password":"Password123!"}]'

# Storage (default: local filesystem)
STORAGE_TYPE=local

# Uncomment for S3-compatible storage (SeaweedFS, AWS S3, Cloudflare R2)
# STORAGE_TYPE=s3
# S3_ENDPOINT=http://seaweedfs:8333
# S3_BUCKET=kuayle-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC=true
# S3_CDN_BASE_URL=

# ---------------------------------------------------------------------------
# Dev Machines — opt-in, requires separate infrastructure
#
# The machine domain MUST be a separate registrable domain (e.g. kuayle-machines.net),
# NOT a sibling subdomain of the main app (e.g. machines.kuayle.example.com).
# Separate registrable domains prevent cookie ambiguity between the main
# application and machine workloads.
#
# DNS requirements:
#   - Wildcard A/AAAA record: *.kuayle-machines.net -> host IP
#
# TLS requirements:
#   - Local/internal: Caddy's internal CA is sufficient (tls internal).
#   - Production: stock Caddy CANNOT issue wildcard certificates via
#     HTTP-01. You MUST either mount an operator-provided wildcard cert
#     or build Caddy with a DNS-01 module (caddy-dns/cloudflare,
#     caddy-dns/route53, etc.) and configure the wildcard block accordingly.
# The dev-machines startup preflight rejects a public production domain while
# an active tls/issuer internal or local_certs directive remains in Caddyfile.
#
# Ingest URL: must be the externally reachable main-domain URL so collector
# containers can reach the backend through Caddy. Do NOT use localhost.
#
# Idle/runtime policy: workspace policy defaults idle pause to 240 minutes;
# keep_running=true bypasses idle pause. Maximum hard runtime is policy-controlled
# and machines are not automatically deleted.
#
# Environment snapshots: Environment Builder saves immutable local OCI images in
# the host Docker image store. Snapshots exclude the repository workspace volume
# and tmpfs secrets; include these local images in backup/migration plans if used.
#
# Workspace disk: Docker's data root MUST be on XFS mounted with pquota or
# prjquota. Rootless/user-namespace Docker is unsupported. The manager verifies
# local-volume hard-quota support at startup and fails closed when unavailable.
#
# Build runtime images first:
#   docker compose --profile dev-machine-images build
# Start the control plane:
#   docker compose --profile dev-machines up -d
# ---------------------------------------------------------------------------
# Keep false for the default deployment. Set true before starting the
# dev-machines profile; its startup preflight fails while this remains false.
DEV_MACHINES_ENABLED=false
DEV_MACHINE_DOMAIN=kuayle-machines.example.net
DEV_MACHINE_ENCRYPTION_KEY=
DEV_MACHINE_INGEST_URL=https://kuayle.example.com/api/dev-machine-ingest
DEV_MACHINE_SESSION_TTL_MINUTES=480
DEV_MACHINE_ACCESS_TICKET_TTL_SECONDS=60
DEV_MACHINE_PULL_IMAGES=false
# Stable gateway container name used for private network attachment.
DEV_MACHINE_GATEWAY_CONTAINER=kuayle-machine-gateway
# Dedicated gateway role provisioned by the dev-machines Compose profile.
# Keep any explicit URL override aligned with this user/password; use a URL-safe
# password here or percent-encode it in the URL.
DEV_MACHINE_GATEWAY_DB_USER=kuayle_gateway
DEV_MACHINE_GATEWAY_DB_PASSWORD=CHANGE_ME_separate_gateway_password
# DEV_MACHINE_GATEWAY_DATABASE_URL=postgres://kuayle_gateway:ENCODED_PASSWORD@postgres:5432/kuayle?sslmode=disable
# Docker host for the manager (default: socket mount)
# DEV_MACHINE_DOCKER_HOST=unix:///var/run/docker.sock
# Numeric group owner of /var/run/docker.sock. Keep 0 for Docker Desktop; on
# Linux replace it with: stat -c '%g' /var/run/docker.sock
DEV_MACHINE_DOCKER_GID=0
# Container seccomp profile: empty = Docker default, "unconfined", or inline JSON
# DEV_MACHINE_SECCOMP_PROFILE=
# AppArmor profile name loaded on the host (requires apparmor on the host)
# DEV_MACHINE_APPARMOR_PROFILE=
# Empty allowlist permits public destinations while always blocking private,
# loopback, link-local, multicast, and literal-IP destinations.
DEV_MACHINE_EGRESS_ALLOWLIST=
DEV_MACHINE_EGRESS_DENYLIST=
# Pinned runtime images (tag or digest). Self-hosting builds these local tags by
# default; pin to trusted registry tags/digests if you pull instead.
# Developer image includes code-server, ttyd, tmux, and pinned OpenCode,
# Claude Code, and Codex CLIs. Provider-specific agent images are pinned separately.
# DEV_MACHINE_IDE_IMAGE=kuayle/dev-machine-ide:0.1.0
# DEV_MACHINE_BROWSER_IMAGE=kuayle/dev-machine-browser:0.1.0
# DEV_MACHINE_COLLECTOR_IMAGE=kuayle/dev-machine-collector:0.1.0
# DEV_MACHINE_EGRESS_IMAGE=kuayle/dev-machine-egress:0.1.0
# DEV_MACHINE_CLAUDE_IMAGE=kuayle/dev-machine-agent-claude:0.1.0
# DEV_MACHINE_OPENCODE_IMAGE=kuayle/dev-machine-agent-opencode:0.1.0
# DEV_MACHINE_CODEX_IMAGE=kuayle/dev-machine-agent-codex:0.1.0
