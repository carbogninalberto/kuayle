FROM golang:1.25.12-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /machine-gateway ./cmd/machine-gateway

FROM alpine:3.22
RUN apk add --no-cache ca-certificates tzdata \
    && addgroup -g 10001 gateway \
    && adduser -D -u 10001 -G gateway gateway
COPY --from=builder /machine-gateway /usr/local/bin/machine-gateway
USER gateway
EXPOSE 8090
ENTRYPOINT ["/usr/local/bin/machine-gateway"]
