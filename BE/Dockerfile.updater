FROM golang:1.25.11-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . ./
RUN CGO_ENABLED=0 go build -o /out/kuayle-updater ./cmd/updater

FROM alpine:3.21
RUN apk add --no-cache bash ca-certificates docker-cli docker-cli-compose git
WORKDIR /repo
COPY --from=builder /out/kuayle-updater /usr/local/bin/kuayle-updater
EXPOSE 8081
CMD ["kuayle-updater"]
